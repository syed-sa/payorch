# Webhook Worker Environment Configuration
# Copy this file to .env and update with your actual values

# ===== Server Configuration =====
SERVER_PORT=8081

# ===== Stripe Configuration =====
STRIPE_WEBHOOK_SECRET=whsec_test_secret_replace_with_your_secret
STRIPE_API_KEY=sk_test_replace_with_your_key

# ===== Razorpay Configuration =====
RAZORPAY_WEBHOOK_SECRET=razorpay_test_secret_replace_with_your_secret
RAZORPAY_KEY_ID=rzp_test_replace_with_your_key_id
RAZORPAY_KEY_SECRET=razorpay_test_secret_replace_with_your_key_secret

# ===== Kafka Configuration =====
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===== Kafka Topics =====
KAFKA_TOPICS_STRIPE_WEBHOOK=stripe.webhook.events
KAFKA_TOPICS_RAZORPAY_WEBHOOK=razorpay.webhook.events

# ===== Logging Configuration =====
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_PAYORCH=DEBUG

# ===== Application Configuration =====
SPRING_APPLICATION_NAME=payorch-webhook-worker
